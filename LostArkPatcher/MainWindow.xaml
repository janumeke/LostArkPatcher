<Window x:Class="LostArkPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LostArkPatcher"
        mc:Ignorable="d"
        Title="《失落的方舟》更新器" SizeToContent="Width" Height="345" ResizeMode="CanMinimize">
    <WrapPanel Margin="10,10,0,5">
        <StackPanel Margin="0,0,10,5" Width="175">
            <Button x:Name="SpecifyLocationButton" Margin="0,0,0,5" Height="25" Content="指定遊戲位置" FontSize="16"/>
            <TextBlock x:Name="LocationLabel" Margin="0,0,0,5" Height="20" FontSize="15" TextTrimming="CharacterEllipsis"/>
            <Border BorderBrush="Black" Margin="0,0,0,5" BorderThickness="1" CornerRadius="5,5,5,5" Padding="10,5,10,5">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold">啟動器</TextBlock>
                    <WrapPanel>
                        <TextBlock Margin="0,0,10,0" Text="目前版本:" FontSize="16"/>
                        <TextBlock x:Name="LauncherCurrentVersionLabel" Text="?" FontSize="16"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Margin="0,0,10,0" Text="最新版本:" FontSize="16"/>
                        <TextBlock x:Name="LauncherLatestVersionLabel" Text="?" FontSize="16"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="Black" Margin="0,0,0,5" BorderThickness="1" CornerRadius="5,5,5,5" Padding="10,5,10,5">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold">遊戲</TextBlock>
                    <WrapPanel>
                        <TextBlock Margin="0,0,10,0" Text="目前版本:" FontSize="16"/>
                        <TextBlock x:Name="GameCurrentVersionLabel" Text="?" FontSize="16"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Margin="0,0,10,0" Text="最新版本:" FontSize="16"/>
                        <TextBlock x:Name="GameLatestVersionLabel" Text="?" FontSize="16"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Button x:Name="UpdateButton" Margin="0,0,0,5" Height="35" Content="更新" FontSize="16"/>
            <Button x:Name="RepairButton" Margin="0,0,0,0" Height="35" Content="修復" FontSize="16"/>
        </StackPanel>
        <TextBox x:Name="LogTextBox" Margin="0,0,10,5" Width="175" FontSize="15" IsReadOnly="True" TextWrapping="Wrap"/>
    </WrapPanel>
</Window>
